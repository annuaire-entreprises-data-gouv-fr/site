{
  "name": "annuaire-entreprises-site",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=22.22.2",
    "npm": ">=10"
  },
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "compile:data": "node scripts/compile-data-yaml.mjs",
    "dev": "npm run compile:data && NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
    "dev:e2e": "VITE_END2END_MOCKING=enabled npm run dev",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "build": "npm run compile:data && vite build && node scripts/sync-nitro-public-assets.mjs && cp instrument.server.mjs .output/server",
    "preview": "vite preview",
    "test:end2end:run": "cypress run --config-file ./cypress/cypress.config.ts",
    "test:end2end:open": "cypress open --config-file ./cypress/cypress.config.ts",
    "test:unit": "MOCK_API_RECHERCHE_ENTREPRISE=true vitest run --exclude='**/(clients/_test|cypress)/*'",
    "test:api-clients": "MOCK_API_RECHERCHE_ENTREPRISE=false vitest run src/clients/_test",
    "test:api-clients:update-snapshots": "MOCK_API_RECHERCHE_ENTREPRISE=false vitest run src/clients/_test --update",
    "test:e2e:api-recherche": "MOCK_API_RECHERCHE_ENTREPRISE=false vitest run cypress/fixtures/recherche-entreprise/generate.test.ts",
    "test:e2e:api-recherche:update-snapshots": "MOCK_API_RECHERCHE_ENTREPRISE=false vitest run cypress/fixtures/recherche-entreprise/generate.test.ts --update",
    "test:watch": "vitest",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1048.0",
    "@react-spring/web": "10.0.3",
    "@sentry/tanstackstart-react": "10.53.1",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-router": "1.170.1",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.2",
    "@tanstack/router-plugin": "1.168.2",
    "@vcarl/remark-headings": "0.1.0",
    "chart.js": "4.5.1",
    "crawler-user-agents": "1.45.0",
    "fast-xml-parser": "5.8.0",
    "maplibre-gl": "5.24.0",
    "nitro": "3.0.260429-beta",
    "openid-client": "^5.7.1",
    "qrcode": "1.5.4",
    "react": "19.2.6",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.6",
    "react-error-boundary": "6.1.1",
    "react-select": "5.10.2",
    "rehype-autolink-headings": "7.1.0",
    "rehype-stringify": "10.0.1",
    "remark-heading-id": "1.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "unified": "11.0.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@fullhuman/postcss-purgecss": "8.0.0",
    "@tanstack/devtools-vite": "0.7.0",
    "@testing-library/cypress": "^10.1.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^22.10.2",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/remark-heading-id": "^1.0.0",
    "@vitejs/plugin-react": "6.0.2",
    "cypress": "15.15.0",
    "js-yaml": "4.1.1",
    "jsdom": "29.1.1",
    "lefthook": "2.1.6",
    "msw": "2.14.6",
    "postcss-flexbugs-fixes": "5.0.2",
    "postcss-preset-env": "11.2.1",
    "typescript": "^5.7.2",
    "ultracite": "7.7.0",
    "vite": "8.0.12",
    "vitest": "^3.0.5"
  }
}
